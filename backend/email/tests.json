{
  "tests": [
    {
      "name": "Welcome email - status 200",
      "method": "POST",
      "path": "/",
      "body": {"action": "welcome", "to": "delivered@resend.dev", "name": "Тест"},
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown", "to": "test@example.com"},
      "expectedStatus": 400,
      "expectedBody": {"error": "unknown action"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Missing to returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "welcome"},
      "expectedStatus": 400,
      "expectedBody": {"error": "missing to"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reset password - missing code returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "reset_password", "to": "test@example.com"},
      "expectedStatus": 400,
      "expectedBody": {"error": "missing code"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cron trial ending",
      "method": "GET",
      "path": "/?cron=trial_ending",
      "expectedStatus": 200
    },
    {
      "name": "Cron reactivation",
      "method": "GET",
      "path": "/?cron=reactivation",
      "expectedStatus": 200
    },
    {
      "name": "Cron drip campaign",
      "method": "GET",
      "path": "/?cron=drip",
      "expectedStatus": 200
    },
    {
      "name": "Cron recurring reminder",
      "method": "GET",
      "path": "/?cron=recurring",
      "expectedStatus": 200
    },
    {
      "name": "Daily bonus email",
      "method": "POST",
      "path": "/",
      "body": {"action": "daily_bonus", "to": "delivered@resend.dev", "name": "Тест", "hours_left": 10},
      "expectedStatus": 200
    },
    {
      "name": "Unknown cron returns 400",
      "method": "GET",
      "path": "/?cron=nonexistent",
      "expectedStatus": 400,
      "expectedBody": {"error": "unknown cron"},
      "bodyMatcher": "partial"
    }
  ]
}