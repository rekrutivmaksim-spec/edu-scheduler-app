{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unauthorized request",
      "method": "GET",
      "path": "/?action=status",
      "expectedStatus": 401
    },
    {
      "name": "Cron onboarding",
      "method": "GET",
      "path": "/?cron=onboarding",
      "expectedStatus": 200,
      "expectedBody": {"welcome": {}, "reminder": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cron streak reminder",
      "method": "GET",
      "path": "/?cron=streak",
      "expectedStatus": 200,
      "expectedBody": {"sent": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cron trial ending",
      "method": "GET",
      "path": "/?cron=trial_ending",
      "expectedStatus": 200,
      "expectedBody": {"sent": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cron reactivation",
      "method": "GET",
      "path": "/?cron=reactivation",
      "expectedStatus": 200,
      "expectedBody": {"day3": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cron daily bonus",
      "method": "GET",
      "path": "/?cron=daily_bonus",
      "expectedStatus": 200,
      "expectedBody": {"push": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Cron expire bonus",
      "method": "GET",
      "path": "/?cron=expire_bonus",
      "expectedStatus": 200,
      "expectedBody": {"push": {}},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown cron returns 400",
      "method": "GET",
      "path": "/?cron=nonexistent",
      "expectedStatus": 400,
      "expectedBody": {"error": "Unknown cron"},
      "bodyMatcher": "partial"
    }
  ]
}