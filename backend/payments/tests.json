{
  "tests": [
    {
      "name": "Get plans - unauthorized",
      "method": "GET",
      "path": "/?action=plans",
      "headers": {"Authorization": "Bearer invalid-token"},
      "expectedStatus": 401
    },
    {
      "name": "Webhook without body returns ok",
      "method": "POST",
      "path": "/",
      "body": {"action": "webhook"},
      "expectedStatus": 200
    },
    {
      "name": "Notify pending payment users",
      "method": "POST",
      "path": "/",
      "body": {"action": "notify_pending_users"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create guest payment - no plan",
      "method": "POST",
      "path": "/",
      "body": {"action": "create_guest_payment", "plan_type": "nonexistent", "fingerprint": "test123"},
      "expectedStatus": 400
    },
    {
      "name": "Create payment - unauthorized",
      "method": "POST",
      "path": "/",
      "headers": {"Authorization": "Bearer invalid-token"},
      "body": {"action": "create_payment", "plan_type": "1month"},
      "expectedStatus": 401
    },
    {
      "name": "Check payment - unauthorized",
      "method": "POST",
      "path": "/",
      "body": {"action": "check_payment", "payment_id": 999},
      "expectedStatus": 401
    },
    {
      "name": "Claim guest payment - no auth",
      "method": "POST",
      "path": "/",
      "body": {"action": "claim_guest_payment", "fingerprint": "test123"},
      "expectedStatus": 401
    },
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    }
  ]
}
