{
  "tests": [
    {
      "name": "Get subscription plans",
      "method": "GET",
      "path": "/?action=plans",
      "headers": {"Authorization": "Bearer mock-token"},
      "expectedStatus": 200
    },
    {
      "name": "Get question packs",
      "method": "GET",
      "path": "/?action=token_packs",
      "headers": {"Authorization": "Bearer mock-token"},
      "expectedStatus": 200
    },
    {
      "name": "Get auto renew info",
      "method": "GET",
      "path": "/?action=auto_renew",
      "headers": {"Authorization": "Bearer mock-token"},
      "expectedStatus": 200
    },
    {
      "name": "Webhook without body returns ok",
      "method": "POST",
      "path": "/",
      "body": {"action": "webhook"},
      "expectedStatus": 200
    },
    {
      "name": "Notify pending payment users",
      "method": "POST",
      "path": "/",
      "body": {"action": "notify_pending_users"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    }
  ]
}